{
  "name": "cypress-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cy:open": "cypress open",
    "cy:run:parallel": "cypress run",
    "cy:run:helper": "cypress run --config reporter=cypress-mochawesome-reporter",
    "cy:parallel:helper": "cypress-parallel -s cy:run:parallel -t 4 -d",

    
    
    "cy:run:all_chat_project": "npm run cy:run:helper -- --spec cypress/e2e/all_chat_project/**/*.cy.js",
    "cy:parallel:all_chat_project": "npm run cy:parallel:helper -- cypress/e2e/all_chat_project/**/*.cy.js",

    "cy:run:other_project": "npm run cy:run:helper -- --spec cypress/e2e/other_project/**/*.cy.js",
    "cy:parallel:other_project": "npm run cy:parallel:helper -- cypress/e2e/other_project/**/*.cy.js"


  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cypress": "^15.13.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-parallel": "^0.15.0",
    "cypress-xpath": "^2.0.1",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.9.8"
  }
}
